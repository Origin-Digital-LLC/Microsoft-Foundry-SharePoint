{
    "name": "Emails",
    "strict": true,
    "description": "A simple list of email addresses.",
    "schema": 
    {
        "type": "object",
        "additionalProperties": false,
        "required": [ "Engineers"],
        "properties": 
        {            
            "Engineers": {
                "type": "array",
                "additionalProperties": false,
                "description": "These are the engineers return from a query.",
                "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [ "Email"],
                    "properties": 
                    {
                        "Email": {
                            "type": "string",
                            "description": "The engineer's email address."
                        }
                    }
                }
            }
        }
    }
}